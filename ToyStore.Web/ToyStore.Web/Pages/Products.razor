@page "/produtos"
@inject ProductService ProductService

<PageTitle>ToyStore - Produtos</PageTitle>

<h1 class="h3 mb-4">Nossos Produtos</h1>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>@_errorMessage
    </div>
}
else if (_products is null)
{
    <Components.Loading.Loading Message="Carregando produtos..." />
}
else if (_products.Count == 0)
{
    <Components.EmptyState.EmptyState
        Title="Nenhum produto encontrado"
        Message="Ainda não há produtos cadastrados."
        Icon="bi-box-seam" />
}
else
{
    <div class="row g-4">
        @foreach (var product in _products)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <Components.ProductCard.ProductCard Product="product" />
            </div>
        }
    </div>
}

@code {
    private List<Dtos.ProductDto>? _products;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _products = await ProductService.GetAllAsync();
        }
        catch (ProductServiceException ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
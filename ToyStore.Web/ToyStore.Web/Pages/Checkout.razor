@page "/checkout"
@inject CartService CartService
@inject OrderService OrderService
@inject NavigationManager NavigationManager

<PageTitle>ToyStore - Checkout</PageTitle>

<h1 class="h3 mb-4">Checkout</h1>

@if (CartService.Items.Count == 0)
{
    <Components.EmptyState.EmptyState
        Title="Carrinho vazio"
        Message="Adicione produtos antes de finalizar a compra."
        Icon="bi-cart-x"
        ActionText="Ver Produtos"
        ActionUrl="/produtos" />
}
else
{
    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger mb-4" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>@_errorMessage
        </div>
    }

    <div class="row g-4">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Dados do Cliente</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Nome</dt>
                        <dd class="col-sm-8">@_customerName</dd>
                        <dt class="col-sm-4 text-muted">E-mail</dt>
                        <dd class="col-sm-8">cliente@toystore.com</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3">Resumo do Pedido</h2>
                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var item in CartService.Items)
                        {
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span>@item.ProductName x @item.Quantity</span>
                                <span>@item.Total.ToString("C2")</span>
                            </li>
                        }
                    </ul>
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-3">
                        <span>Total</span>
                        <span class="text-primary">@CartService.GetTotal().ToString("C2")</span>
                    </div>
                    <button class="btn btn-primary w-100"
                            @onclick="FinalizarCompra"
                            disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Processando...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-1"></i>
                            <span>Finalizar Compra</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Nome mockado — será substituído por dados reais de autenticação em etapas futuras.
    private readonly string _customerName = "Cliente ToyStore";
    private bool _isLoading;
    private string? _errorMessage;

    private async Task FinalizarCompra()
    {
        if (_isLoading || CartService.Items.Count == 0)
            return;

        _isLoading = true;
        _errorMessage = null;

        try
        {
            var dto = new CreateOrderDto
            {
                CustomerName = _customerName,
                Items = CartService.Items.Select(i => new CreateOrderItemDto
                {
                    ToyName = i.ProductName,
                    Quantity = i.Quantity,
                    UnitPrice = i.UnitPrice
                }).ToList()
            };

            var order = await OrderService.CreateOrderAsync(dto);

            // Pedido criado — a partir daqui o backend processa via Azure Service Bus.
            // O frontend não aguarda pagamento, estoque ou envio.
            CartService.Clear();

            NavigationManager.NavigateTo($"/pedido-finalizado/{order.Id}");
        }
        catch (OrderServiceException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
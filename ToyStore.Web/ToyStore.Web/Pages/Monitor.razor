@page "/monitor/{OrderId:guid}"
@using ToyStore.Web.Components.OrderTimeline
@inject OrderService OrderService

<PageTitle>ToyStore - Monitor de Pedido</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Monitor de Pedido</h1>
    <button class="btn btn-outline-primary btn-sm" @onclick="Refresh" disabled="@_isLoading">
        @if (_isLoading)
        {
            <span class="spinner-border spinner-border-sm me-1"></span>
        }
        else
        {
            <i class="bi bi-arrow-clockwise me-1"></i>
        }
        Atualizar
    </button>
</div>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-1"></i>@_errorMessage
    </div>
}
else if (_isLoading)
{
    <Loading Message="Consultando pedido..." />
}
else if (_order is null)
{
    <EmptyState
        Title="Pedido não encontrado"
        Message="Verifique o número do pedido e tente novamente."
        Icon="bi-search"
        ActionText="Voltar para Home"
        ActionUrl="/" />
}
else
{
    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h2 class="h6 text-muted mb-3">DETALHES DO PEDIDO</h2>
                    <dl class="row mb-0 small">
                        <dt class="col-5 text-muted">Número</dt>
                        <dd class="col-7 text-truncate" title="@_order.Id">@_order.Id</dd>

                        <dt class="col-5 text-muted">Cliente</dt>
                        <dd class="col-7">@_order.CustomerName</dd>

                        <dt class="col-5 text-muted">Total</dt>
                        <dd class="col-7 fw-semibold text-primary">@_order.TotalAmount.ToString("C2")</dd>

                        <dt class="col-5 text-muted">Criado em</dt>
                        <dd class="col-7">@_order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</dd>

                        <dt class="col-5 text-muted">Status atual</dt>
                        <dd class="col-7">
                            <span class="badge @GetStatusBadgeClass(_order.Status)">
                                @GetStatusLabel(_order.Status)
                            </span>
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body small text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    O pagamento, a reserva de estoque e o envio são processados de forma
                    assíncrona pelo <strong>Azure Service Bus</strong>. Use o botão
                    <strong>Atualizar</strong> para acompanhar o avanço.
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h6 text-muted mb-4">FLUXO DE PROCESSAMENTO</h2>
                    <OrderTimeline Status="_order.Status" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid OrderId { get; set; }

    private OrderResponseDto? _order;
    private bool _isLoading;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync() => await LoadOrder();

    private async Task Refresh() => await LoadOrder();

    private async Task LoadOrder()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _order = await OrderService.GetByIdAsync(OrderId);
        }
        catch (OrderServiceException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetStatusLabel(OrderStatusDto status) => status switch
    {
        OrderStatusDto.Pending            => "Pendente",
        OrderStatusDto.PaymentProcessing  => "Processando Pagamento",
        OrderStatusDto.Paid               => "Pago",
        OrderStatusDto.PaymentFailed      => "Pagamento Falhou",
        OrderStatusDto.Cancelled          => "Cancelado",
        OrderStatusDto.InventoryReserved  => "Estoque Reservado",
        OrderStatusDto.Shipped            => "Enviado",
        OrderStatusDto.Completed          => "Concluído",
        _                                 => "Desconhecido"
    };

    private static string GetStatusBadgeClass(OrderStatusDto status) => status switch
    {
        OrderStatusDto.Paid or
        OrderStatusDto.InventoryReserved or
        OrderStatusDto.Shipped or
        OrderStatusDto.Completed          => "text-bg-success",
        OrderStatusDto.PaymentProcessing  => "text-bg-warning",
        OrderStatusDto.PaymentFailed or
        OrderStatusDto.Cancelled          => "text-bg-danger",
        _                                 => "text-bg-secondary"
    };
}